# ───────────────────────────────────────────────────────────────
# Application
# ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Public base URL of the API (used by better-auth for cookies/redirects)
BETTER_AUTH_URL=http://localhost:3000

# 32+ char secret used to sign sessions. Generate with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-long-random-secret

# Comma-separated list of allowed CORS origins (use * only for local dev)
CORS_ORIGIN=http://localhost:3000

# ───────────────────────────────────────────────────────────────
# Database (MySQL)
# ───────────────────────────────────────────────────────────────
# When running via docker-compose, host is the service name `mysql`.
# For local (non-docker) dev, use 127.0.0.1.
DATABASE_URL=mysql://root:rootpassword@mysql:3306/songshare

# Used by the mysql container in docker-compose.yml
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=songshare

# ───────────────────────────────────────────────────────────────
# File storage
# ───────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
# 25 MB
MAX_UPLOAD_BYTES=26214400

# ───────────────────────────────────────────────────────────────
# Demo data
# ───────────────────────────────────────────────────────────────
# Seed demo data on container start: manager@example.com / songwriter@example.com
# (both password "Passw0rd!"). Leave unset/false outside local demos.
SEED_ON_START=true
