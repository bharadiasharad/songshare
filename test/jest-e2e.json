{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/../src/$1",
    "^better-auth/node$": "<rootDir>/mocks/better-auth-node.ts",
    "^better-auth/adapters/prisma$": "<rootDir>/mocks/better-auth-prisma.ts",
    "^better-auth/plugins$": "<rootDir>/mocks/better-auth-plugins.ts",
    "^better-auth$": "<rootDir>/mocks/better-auth.ts"
  }
}
